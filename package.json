{
  "name": "@openzeppelin/hardhat-tron",
  "version": "0.1.0-dev.0",
  "description": "Hardhat plugin for compiling and deploying Solidity contracts to the TRON TVM via a local java-tron (TRE) container.",
  "license": "MIT",
  "private": true,
  "type": "commonjs",
  "main": "src/index.js",
  "types": "src/types.d.ts",
  "files": [
    "src/**/*",
    "docker/**/*",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "lint": "prettier --check 'src/**/*.{js,ts}'",
    "format": "prettier --write 'src/**/*.{js,ts}'",
    "docker:build-jar": "bash docker/build-jar.sh"
  },
  "peerDependencies": {
    "hardhat": "^2.26.0",
    "@nomicfoundation/hardhat-ethers": "^3.0.0",
    "@nomicfoundation/hardhat-chai-matchers": "^2.0.0",
    "ethers": "^6.14.0"
  },
  "dependencies": {
    "micromatch": "^4.0.8",
    "solc": "^0.8.26",
    "tronweb": "^6.2.2"
  },
  "devDependencies": {
    "prettier": "^3.3.3"
  }
}
